{
  "name": "cuhksz-source",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "predev": "npm run generate:manifest",
    "dev": "vite",
    "generate:manifest": "node scripts/generate-manifest.mjs",
    "sync:lanzou": "node scripts/sync-lanzou.mjs",
    "plan:renames": "node scripts/plan-resource-renames.mjs",
    "apply:renames": "node scripts/apply-resource-renames.mjs",
    "audit:pdf-titles": "python3 scripts/audit-pdf-titles.py",
    "package:archives": "node scripts/package-course-archives.mjs",
    "build": "npm run generate:manifest && tsc -b && vite build",
    "test": "node --test scripts/*.test.mjs",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.23.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@types/archiver": "^8.0.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "archiver": "^8.0.0",
    "eslint": "^10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6",
    "typescript-eslint": "^8",
    "vite": "^8"
  }
}
